---
import { STATS } from '../config/site';

const stats = [
    {
        value: `+${STATS.servicesCompleted}`,
        label: "Servicios Realizados",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.83-5.83M15.17 11.42a4 4 0 11-5.66-5.66 4 4 0 015.66 5.66zM5.5 8.5L2 12m0 0l3.5 3.5M2 12h14" /></svg>',
    },
    {
        value: `+${STATS.yearsExperience}`,
        label: "Años de Experiencia",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>',
    },
    {
        value: `+${STATS.happyClients}`,
        label: "Clientes Satisfechos",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg>',
    },
    {
        value: `${STATS.warrantyPercent}%`,
        label: "Refacciones Originales",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.746 3.746 0 0 1 21 12Z" /></svg>',
    },
];
---

<section class="py-20 md:py-24 bg-blue-50 relative overflow-hidden border-y border-blue-100">
    <!-- Decorative -->
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 2px 2px, #3b82f6 1px, transparent 0); background-size: 40px 40px;"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-blue-200/50 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-14 reveal">
            <span class="inline-block text-blue-700 font-bold text-sm tracking-widest uppercase mb-3">En Números</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-blue-950 mb-4">
                Resultados que hablan por sí solos
            </h2>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 reveal-stagger">
            {stats.map(stat => (
                <div class="text-center group">
                    <div class="w-16 h-16 mx-auto rounded-2xl bg-white shadow-sm border border-blue-100 flex items-center justify-center mb-4 group-hover:bg-blue-100 group-hover:scale-110 group-hover:shadow-md transition-all duration-500">
                        <Fragment set:html={stat.icon} />
                    </div>
                    <div class="text-4xl md:text-5xl font-extrabold text-blue-950 mb-2">
                        {stat.value}
                    </div>
                    <p class="text-blue-800 text-sm font-medium">{stat.label}</p>
                </div>
            ))}
        </div>
    </div>
</section>
