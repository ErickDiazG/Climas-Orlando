---
import { STATS } from '../config/site';

const stats = [
    {
        value: `+${STATS.servicesCompleted}`,
        label: "Climas instalados y reparados",
    },
    {
        value: `+${STATS.yearsExperience}`,
        label: "Años de servicio continuo",
    },
    {
        value: `${STATS.warrantyPercent}%`,
        label: "Garantía en cada trabajo",
    },
    {
        value: "24h",
        label: "Atención el mismo día",
    },
];
---

<!-- Dark navy stats section — Revised metrics -->
<section class="bg-slate-900 py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-slate-700 reveal-stagger reveal">
            {stats.map((stat) => (
                <div class="text-center px-6 py-4">
                    <div class="text-4xl md:text-5xl font-black text-white mb-1">
                        {stat.value}
                    </div>
                    <p class="text-slate-400 text-sm font-medium uppercase tracking-wider">{stat.label}</p>
                </div>
            ))}
        </div>
    </div>
</section>
