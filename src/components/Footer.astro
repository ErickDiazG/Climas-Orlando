---
import { CONTACT, SITE } from '../config/site';
import { Image } from 'astro:assets';
import logoImg from '../../public/images/multiservicios-diaz-logo.webp';
---

<footer class="bg-gray-50 text-slate-600 pt-16 pb-28 md:pb-12 relative overflow-hidden border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
            
            <!-- Column 1: Brand -->
            <div class="flex flex-col items-center text-center lg:col-span-1">
                <Image 
                    src={logoImg} 
                    alt="Logo Multiservicios Diaz" 
                    width={160}
                    height={160}
                    class="h-16 md:h-20 w-auto object-contain mb-6 mix-blend-multiply" 
                />
                <p class="text-slate-600 leading-relaxed text-sm max-w-sm mx-auto">
                    Su socio de confianza para climatización y línea blanca en Reynosa. Calidad, honestidad y eficiencia en cada servicio.
                </p>
            </div>

            <!-- Column 2: Enlaces (Hidden on Mobile) -->
            <div class="hidden md:block">
                <h4 class="font-bold text-slate-900 tracking-wider mb-6 uppercase text-sm">Enlaces</h4>
                <ul class="space-y-4 text-sm">
                    <li><a href="/" class="text-slate-500 hover:text-blue-600 transition-colors">Inicio</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-blue-600 transition-colors">Servicios</a></li>
                    <li><a href="#sobre-nosotros" class="text-slate-500 hover:text-blue-600 transition-colors">Mi Experiencia</a></li>
                </ul>
            </div>

            <!-- Column 3: Servicios (Hidden on Mobile) -->
            <div class="hidden md:block">
                <h4 class="font-bold text-slate-900 tracking-wider mb-6 uppercase text-sm">Servicios</h4>
                <ul class="space-y-4 text-sm">
                    <li><a href="#servicios" class="text-slate-500 hover:text-blue-600 transition-colors">Minisplits</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-blue-600 transition-colors">Lavadoras</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-blue-600 transition-colors">Mantenimiento</a></li>
                </ul>
            </div>

            <!-- Column 4: Contacto -->
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <h4 class="font-bold text-slate-900 tracking-wider mb-6 uppercase text-sm">Contacto</h4>
                <ul class="space-y-4">
                    <li class="flex items-start justify-center md:justify-start gap-3 group">
                        <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 shrink-0 group-hover:bg-blue-600 group-hover:text-white transition-all">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                        </div>
                        <span class="text-slate-600 text-sm leading-snug">{CONTACT.coverageArea}</span>
                    </li>
                    <li class="flex items-center justify-center md:justify-start gap-3 group">
                        <a href={`tel:${CONTACT.phone}`} class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 shrink-0 group-hover:bg-blue-600 group-hover:text-white transition-all">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.25-3.95-6.847-6.847l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
                            </div>
                            <span class="text-slate-600 text-sm font-bold group-hover:text-blue-600 transition-colors">{CONTACT.phoneDisplay}</span>
                        </a>
                    </li>
                </ul>
            </div>

        </div>

        <!-- Bottom Bar (Aceptamos Left, Dev Right) -->
        <div class="border-t border-gray-200 pt-8 flex flex-col md:flex-row justify-between items-center gap-6">
            
            <!-- Payment Methods -->
            <div class="flex items-center gap-4">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mr-2">Aceptamos:</span>
                <div class="flex items-center gap-3">
                    <div class="p-1.5 bg-white border border-gray-100 rounded-md text-green-600 shadow-sm" title="Efectivo">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
                    </div>
                    <div class="p-1.5 bg-white border border-gray-100 rounded-md text-blue-600 shadow-sm" title="Transferencia">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" /></svg>
                    </div>
                    <div class="p-1.5 bg-white border border-gray-100 rounded-md text-amber-500 shadow-sm" title="Tarjetas">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" /></svg>
                    </div>
                </div>
            </div>

            <!-- Developer Link -->
            <a href="https://devdiazlabs.com" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 text-xs font-medium text-slate-500 hover:text-slate-800 transition-all duration-300">
                <span>Desarrollado por</span>
                <span class="relative">
                    <span class="bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent font-bold tracking-tight">DevDiaz Labs</span>
                    <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-gradient-to-r from-blue-600 to-cyan-500 transition-all duration-300 group-hover:w-full"></span>
                </span>
            </a>
        </div>
    </div>
</footer>
