---
import { CONTACT, SITE } from '../config/site';
import { Image } from 'astro:assets';
import logoImg from '../../public/images/Logo SD.webp';
---

<footer class="bg-slate-900 text-slate-400 pt-16 pb-8 border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-12">
            
            <!-- Column 1: Brand -->
            <div class="lg:col-span-1">
                <div class="flex items-center gap-3 mb-5">
                    <div class="w-11 h-11 bg-white rounded-full flex items-center justify-center flex-shrink-0">
                        <Image 
                            src={logoImg} 
                            alt="Logo Servicios Diaz" 
                            width={80}
                            height={80}
                            class="w-full h-full object-cover mix-blend-multiply rounded-full" 
                        />
                    </div>
                    <div>
                        <p class="font-black text-white text-sm leading-none tracking-tight">SERVICIOS <span class="text-blue-400">DIAZ</span></p>
                        <p class="text-slate-500 text-[10px] uppercase tracking-widest">Reynosa, Tamps.</p>
                    </div>
                </div>
                <p class="text-slate-500 text-sm leading-relaxed">
                    Técnico especialista en climatización y línea blanca. Calidad, honestidad y eficiencia en cada servicio.
                </p>
            </div>

            <!-- Column 2: Links -->
            <div class="hidden md:block">
                <h4 class="font-bold text-white text-xs tracking-widest uppercase mb-5">Navegación</h4>
                <ul class="space-y-3 text-sm">
                    <li><a href="/" class="text-slate-500 hover:text-white transition-colors">Inicio</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-white transition-colors">Servicios</a></li>
                    <li><a href="#sobre-nosotros" class="text-slate-500 hover:text-white transition-colors">Mi Experiencia</a></li>
                    <li><a href="#contacto" class="text-slate-500 hover:text-white transition-colors">Contacto</a></li>
                </ul>
            </div>

            <!-- Column 3: Services -->
            <div class="hidden md:block">
                <h4 class="font-bold text-white text-xs tracking-widest uppercase mb-5">Servicios</h4>
                <ul class="space-y-3 text-sm">
                    <li><a href="#servicios" class="text-slate-500 hover:text-white transition-colors">Venta de Minisplits</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-white transition-colors">Reparación de Lavadoras</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-white transition-colors">Mantenimiento de Climas</a></li>
                </ul>
            </div>

            <!-- Column 4: Contact -->
            <div>
                <h4 class="font-bold text-white text-xs tracking-widest uppercase mb-5">Contacto</h4>
                <ul class="space-y-4 text-sm">
                    <li>
                        <a href={`tel:${CONTACT.phone}`} class="flex items-center gap-3 text-slate-400 hover:text-white transition-colors group">
                            <svg class="w-4 h-4 text-blue-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.25-3.95-6.847-6.847l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
                            {CONTACT.phoneDisplay}
                        </a>
                    </li>
                    <li class="flex items-start gap-3 text-slate-400">
                        <svg class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                        <span class="text-sm leading-snug">{CONTACT.coverageArea}</span>
                    </li>
                </ul>
            </div>

        </div>

        <!-- Bottom Bar -->
        <div class="border-t border-slate-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
            
            <!-- Payment Methods -->
            <div class="flex items-center gap-4">
                <span class="text-[10px] font-bold text-slate-600 uppercase tracking-widest">Formas de pago:</span>
                <div class="flex items-center gap-2">
                    <div class="px-2 py-1 bg-slate-800 border border-slate-700 rounded text-slate-400 text-xs font-bold">Efectivo</div>
                    <div class="px-2 py-1 bg-slate-800 border border-slate-700 rounded text-slate-400 text-xs font-bold">Transferencia</div>
                    <div class="px-2 py-1 bg-slate-800 border border-slate-700 rounded text-slate-400 text-xs font-bold">Tarjeta</div>
                </div>
            </div>

            <!-- Developer Link -->
            <a href="https://devdiazlabs.com" target="_blank" rel="noopener noreferrer"
               class="group flex items-center gap-2 text-xs font-medium text-slate-600 hover:text-slate-400 transition-all duration-300">
                <span>Desarrollado por</span>
                <span class="bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent font-bold">DevDiaz Labs</span>
            </a>
        </div>

    </div>
</footer>
