---
import { CONTACT, WHATSAPP } from '../config/site';
import { Image } from 'astro:assets';
import logoImg from '../../public/images/Logo SD.webp';
---

<footer class="bg-dark-950 text-slate-400 pt-16 pb-8 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8 mb-12">
            
            <!-- Brand -->
            <div class="lg:col-span-1">
                <div class="flex items-center gap-3 mb-5">
                    <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center flex-shrink-0">
                        <Image 
                            src={logoImg} 
                            alt="Logo Servicios Diaz" 
                            width={80}
                            height={80}
                            class="w-full h-full object-cover mix-blend-multiply rounded-full" 
                        />
                    </div>
                    <div>
                        <p class="font-black text-white text-base leading-none tracking-tight">SERVICIOS <span class="text-brand-400">DIAZ</span></p>
                        <p class="text-slate-500 text-[10px] uppercase tracking-widest">Reynosa, Tamps.</p>
                    </div>
                </div>
                <p class="text-slate-500 text-sm leading-relaxed">
                    Técnico especialista en climatización y línea blanca. Calidad, honestidad y eficiencia en cada servicio.
                </p>
                <!-- Social Commented Out -->
                {/* 
                <div class="flex gap-3 mt-5">
                    <a href="https://facebook.com/climasdiaz" target="_blank" rel="noopener" class="w-10 h-10 rounded-xl bg-white/5 hover:bg-brand-500/20 flex items-center justify-center text-slate-500 hover:text-brand-400 transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                    <a href={WHATSAPP.default} target="_blank" class="w-10 h-10 rounded-xl bg-white/5 hover:bg-green-500/20 flex items-center justify-center text-slate-500 hover:text-green-400 transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                    </a>
                </div>
                */}
            </div>

            <!-- Links -->
            <div class="hidden lg:block">
                <h4 class="font-bold text-white text-xs tracking-widest uppercase mb-5">Navegación</h4>
                <ul class="space-y-3 text-sm">
                    <li><a href="#inicio" class="text-slate-500 hover:text-white transition-colors">Inicio</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-white transition-colors">Servicios</a></li>
                    <li><a href="#sobre-nosotros" class="text-slate-500 hover:text-white transition-colors">Sobre Mí</a></li>
                </ul>
            </div>

            <!-- Services -->
            <div class="hidden lg:block">
                <h4 class="font-bold text-white text-xs tracking-widest uppercase mb-5">Servicios</h4>
                <ul class="space-y-3 text-sm">
                    <li><a href="#servicios" class="text-slate-500 hover:text-white transition-colors">Minisplits</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-white transition-colors">Lavadoras</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-white transition-colors">Mantenimiento</a></li>
                    <li><a href="#servicios" class="text-slate-500 hover:text-white transition-colors">Carga de Gas</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div class="hidden lg:block">
                <h4 class="font-bold text-white text-xs tracking-widest uppercase mb-5">Contacto</h4>
                <ul class="space-y-4 text-sm">
                    <li>
                        <a href={`tel:${CONTACT.phone}`} class="flex items-center gap-3 text-slate-400 hover:text-white transition-colors group">
                            <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.25-3.95-6.847-6.847l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
                            {CONTACT.phoneDisplay}
                        </a>
                    </li>
                    <li class="flex items-start gap-3 text-slate-400">
                        <svg class="w-4 h-4 text-brand-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                        <span class="leading-snug">{CONTACT.coverageArea}</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-4">
                <span class="text-[10px] font-bold text-slate-600 uppercase tracking-widest">Formas de pago:</span>
                <div class="flex items-center gap-2">
                    <div class="px-2 py-1 bg-white/5 border border-white/10 rounded text-slate-500 text-xs font-bold">Efectivo</div>
                    <div class="px-2 py-1 bg-white/5 border border-white/10 rounded text-slate-500 text-xs font-bold">Transferencia</div>
                    <div class="px-2 py-1 bg-white/5 border border-white/10 rounded text-slate-500 text-xs font-bold">Tarjeta</div>
                </div>
            </div>

            <a href="https://devdiazlabs.com" target="_blank" rel="noopener noreferrer"
               class="group flex items-center gap-2 text-xs font-medium text-slate-600 hover:text-slate-400 transition-all duration-300">
                <span>Desarrollado por</span>
                <span class="bg-gradient-to-r from-brand-400 to-brand-500 bg-clip-text text-transparent font-bold">DevDiaz Labs</span>
            </a>
        </div>

    </div>
</footer>
