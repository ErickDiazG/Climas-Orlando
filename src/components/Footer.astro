---
import { CONTACT, SOCIAL, WHATSAPP, SITE } from '../config/site';
---

<footer class="bg-white text-slate-600 pt-20 pb-8 relative overflow-hidden border-t border-gray-200">
    <!-- Decorative border replaced top gradient -->

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
            <!-- Brand -->
            <div class="lg:col-span-1">
                <div class="flex items-center gap-2.5 mb-6">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
                        <span class="material-icons-outlined text-white text-xl">ac_unit</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="font-extrabold text-2xl text-slate-900 leading-none">CLIMAS ORLANDO</span>
                        <span class="text-[0.65rem] font-bold tracking-[0.2em] text-blue-600 mt-0.5 uppercase">Minisplits y Lavadoras</span>
                    </div>
                </div>
                <p class="text-slate-600 leading-relaxed mb-6 text-sm">
                    Su socio de confianza para climatización y línea blanca. Calidad, honestidad y eficiencia en cada servicio.
                </p>
                <div class="hidden gap-3">
                    <a href={SOCIAL.facebook} target="_blank" class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center text-slate-600 hover:bg-blue-600 hover:text-white transition-all duration-300">
                        <span class="material-icons-outlined text-lg">facebook</span>
                    </a>
                    <a href={WHATSAPP.default} target="_blank" class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center text-slate-600 hover:bg-green-600 hover:text-white transition-all duration-300">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                    </a>
                </div>
            </div>

            <!-- Quick Links -->
            <div>
                <h4 class="font-bold text-slate-900 text-sm uppercase tracking-widest mb-6">Enlaces</h4>
                <ul class="space-y-3">
                    <li><a href="#inicio" class="text-slate-600 hover:text-blue-600 transition-colors duration-200 text-sm">Inicio</a></li>
                    <li><a href="#servicios" class="text-slate-600 hover:text-blue-600 transition-colors duration-200 text-sm">Servicios</a></li>
                    <li><a href="#sobre-nosotros" class="text-slate-600 hover:text-blue-600 transition-colors duration-200 text-sm">Sobre Nosotros</a></li>
                    <li><a href="#faq" class="text-slate-600 hover:text-blue-600 transition-colors duration-200 text-sm">Preguntas Frecuentes</a></li>
                    <li><a href="#contacto" class="text-slate-600 hover:text-blue-600 transition-colors duration-200 text-sm">Contacto</a></li>
                </ul>
            </div>

            <!-- Services -->
            <div>
                <h4 class="font-bold text-slate-900 text-sm uppercase tracking-widest mb-6">Servicios</h4>
                <ul class="space-y-3">
                    <li><a href={WHATSAPP.ventaEquipos} target="_blank" class="text-slate-600 hover:text-blue-600 transition-colors duration-200 text-sm">Venta de Equipos Mirage</a></li>
                    <li><a href={WHATSAPP.reparacionLavadoras} target="_blank" class="text-slate-600 hover:text-blue-600 transition-colors duration-200 text-sm">Reparación de Lavadoras</a></li>
                    <li><a href={WHATSAPP.mantenimientoClimas} target="_blank" class="text-slate-600 hover:text-blue-600 transition-colors duration-200 text-sm">Mantenimiento de Climas</a></li>
                </ul>
            </div>

            <!-- Contact -->
            <div>
                <h4 class="font-bold text-slate-900 text-sm uppercase tracking-widest mb-6">Contacto</h4>
                <ul class="space-y-4">
                    <li class="flex items-start gap-3">
                        <span class="material-icons-outlined text-blue-600 text-lg mt-0.5">location_on</span>
                        <span class="text-sm">{CONTACT.coverageArea}</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="material-icons-outlined text-blue-600 text-lg">phone</span>
                        <a href={`tel:${CONTACT.phone}`} class="hover:text-blue-600 transition-colors text-sm">{CONTACT.phoneDisplay}</a>
                    </li>

                </ul>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class="border-t border-gray-200 pt-8 flex justify-center items-center">
            <a href="https://devdiazlabs.com" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-slate-800 transition-all duration-300">
                <span>Desarrollado por</span>
                <span class="relative">
                    <span class="bg-gradient-to-r from-blue-600 to-cyan-500 bg-clip-text text-transparent font-bold tracking-tight">DevDiaz Labs</span>
                    <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-gradient-to-r from-blue-600 to-cyan-500 transition-all duration-300 group-hover:w-full"></span>
                </span>
            </a>
        </div>
    </div>
</footer>
