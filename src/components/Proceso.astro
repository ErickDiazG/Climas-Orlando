---
const steps = [
    {
        number: "01",
        title: "Contáctame",
        description: "Escríbeme por WhatsApp o llámame. Te guiaré desde el primer momento.",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.068.157 2.148.279 3.238.364.466.037.893.281 1.153.671L12 21l2.652-3.978c.26-.39.687-.634 1.153-.67 1.09-.086 2.17-.208 3.238-.365 1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" /></svg>',
    },
    {
        number: "02",
        title: "Diagnóstico",
        description: "Visito tu domicilio para evaluar el equipo y determinar la solución.",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>',
    },
    {
        number: "03",
        title: "Cotización Transparente",
        description: "Presupuesto detallado y sin sorpresas. Tú apruebas antes de que comience.",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>',
    },
    {
        number: "04",
        title: "Solución Garantizada",
        description: "Trabajo con refacciones nuevas y doy garantía.",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.746 3.746 0 0 1 21 12Z" /></svg>',
    },
];
---

<section class="py-20 md:py-28 bg-gray-50 relative overflow-hidden">
    <!-- Decorative -->
    <div class="absolute top-20 right-0 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-0 w-72 h-72 bg-blue-500/5 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Section Header -->
        <div class="text-center mb-16 reveal">
            <span class="inline-block text-blue-600 font-bold text-sm tracking-widest uppercase mb-3">Cómo Trabajo</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 mb-4">
                Proceso simple, resultados profesionales
            </h2>
            <p class="text-slate-600 text-lg max-w-2xl mx-auto">
                En 4 pasos sencillos resuelvo tu problema. Sin complicaciones.
            </p>
        </div>

        <!-- Steps Grid — ALL icons use the same color for visual consistency -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 reveal-stagger">
            {steps.map((step, i) => (
                <div class="relative group">
                    {/* Connector line */}
                    {i < steps.length - 1 && (
                        <div class="hidden lg:block absolute top-12 left-[60%] w-[calc(100%-20%)] h-0.5 bg-gradient-to-r from-gray-200 to-gray-200/0"></div>
                    )}

                    <div class="text-center">
                        <div class="w-24 h-24 mx-auto rounded-3xl bg-slate-900 flex items-center justify-center mb-6 shadow-xl shadow-slate-900/25 group-hover:-translate-y-2 transition-transform duration-500">
                            <Fragment set:html={step.icon} />
                        </div>

                        <span class="text-xs font-bold text-blue-600 tracking-widest uppercase">Paso {step.number}</span>
                        <h3 class="text-xl font-extrabold text-slate-900 mt-2 mb-3">{step.title}</h3>
                        <p class="text-slate-600 text-sm leading-relaxed">{step.description}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
