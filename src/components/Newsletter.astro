---
import { WHATSAPP } from '../config/site';
---

<section id="oferta" class="py-20 md:py-28 bg-white relative overflow-hidden">
    <!-- Decorative -->
    <div class="absolute inset-0 bg-blue-600">
        <!-- SVG Pattern -->
        <svg class="absolute inset-0 w-full h-full opacity-10" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <pattern id="grid-pattern" width="40" height="40" patternUnits="userSpaceOnUse">
                    <path d="M0 40L40 0H20L0 20M40 40V20L20 40" fill="currentColor"></path>
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#grid-pattern)"></rect>
        </svg>
        <div class="absolute top-0 right-0 w-96 h-96 bg-blue-400 rounded-full blur-[100px] opacity-40 translate-x-1/3 -translate-y-1/3"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-800 rounded-full blur-[100px] opacity-40 -translate-x-1/3 translate-y-1/3"></div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center reveal">
        <div class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-[2rem] p-8 md:p-12 lg:p-16 shadow-2xl">
            <span class="inline-block px-4 py-1.5 rounded-full bg-amber-400 text-amber-900 font-bold text-xs tracking-widest uppercase mb-6 shadow-lg shadow-amber-500/30 transform -rotate-1">Oferta Exclusiva Web</span>
            
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mb-6 leading-tight">
                ¿Quieres un <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-amber-500">10% de descuento</span> en tu primer servicio?
            </h2>
            
            <p class="text-blue-100 text-base md:text-lg mb-10 max-w-2xl mx-auto leading-relaxed">
                Únete a nuestra lista de clientes VIP y recibe tu cupón inmediato. También te avisaremos cuando tengamos promociones especiales de temporada (mantenimientos, cargas de gas, etc.). Sin spam, solo ahorros.
            </p>

            <form action="https://formspree.io/f/xoqqaeez" method="POST" class="max-w-md mx-auto relative group">
                <input 
                    type="email" 
                    name="email" 
                    required 
                    placeholder="Ingresa tu correo electrónico..."
                    class="w-full bg-white/10 border-2 border-white/20 text-white placeholder-blue-200 rounded-xl px-6 py-4 outline-none focus:border-white/50 focus:bg-white/20 transition-all duration-300"
                />
                
                <!-- Added a hidden field to know the origin -->
                <input type="hidden" name="_subject" value="¡Nuevo cliente registrado para el 10% de descuento!">
                <input type="hidden" name="_autoresponse" value="¡Gracias por registrarte! Muestra este correo a nuestro técnico para hacer válido tu 10% de descuento en tu primer servicio de mantenimiento o reparación de Multiservicios Diaz. Agenda tu cita al WhatsApp: +52 899 216 3741.">

                <button type="submit" class="mt-4 w-full sm:w-auto sm:absolute sm:right-2 sm:top-2 sm:mt-0 px-6 py-2.5 bg-white text-blue-600 font-bold rounded-lg shadow-lg hover:bg-blue-50 hover:scale-105 transition-all duration-300">
                    Obtener Cupón
                </button>
            </form>
            <p class="text-blue-200/60 text-xs mt-4">
                * Válido únicamente en mano de obra. Nos comunicaremos a tu correo.
            </p>
        </div>
    </div>
</section>
