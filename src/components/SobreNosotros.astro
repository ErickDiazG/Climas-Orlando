---
import { STATS, WHATSAPP } from '../config/site';
import { Image } from 'astro:assets';
import staffImg from '../../public/images/sobre-nosotros.webp';

const trustPoints = [
    { icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", text: "Técnico con más de 4 años de experiencia" },
    { icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", text: "Diagnóstico honesto y transparente" },
    { icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", text: "Refacciones originales" },
    { icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", text: "Garantía en cada trabajo" },
    { icon: "M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z", text: "Precios directos sin cargos sorpresa" },
    { icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z", text: "100% local - Servicio a domicilio" },
];
---

<section id="sobre-nosotros" class="py-20 lg:py-28 bg-white relative overflow-hidden">
    <!-- Background decorations -->
    <div class="absolute top-20 left-0 w-72 h-72 bg-brand-500/5 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-20 right-0 w-96 h-96 bg-warm-500/5 rounded-full blur-[120px]"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            <!-- Image Side -->
            <div class="relative order-2 lg:order-1">
                <div class="relative rounded-3xl overflow-hidden shadow-2xl border border-slate-200">
                    <Image 
                        src={staffImg} 
                        alt="Orlando Diaz - Experto de Servicios Diaz en Reynosa" 
                        width={600}
                        height={700}
                        class="w-full h-[400px] lg:h-[550px] object-cover"
                        loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-white/90 via-transparent to-transparent"></div>
                </div>
                
                <!-- Experience badge -->
                <div class="absolute -bottom-6 left-4 right-4 md:left-8 md:right-8 bg-white shadow-2xl border border-slate-100 rounded-2xl px-4 py-3 md:px-6 md:py-4">
                    <div class="flex items-center justify-around md:justify-between gap-2 md:gap-6">
                        <div class="flex flex-col sm:flex-row items-center text-center sm:text-left gap-1 sm:gap-3">
                            <div class="text-2xl md:text-4xl font-black text-brand-600">+{STATS.yearsExperience}</div>
                            <div>
                                <p class="font-bold text-slate-900 text-[10px] md:text-sm leading-tight">Años sirviendo</p>
                                <p class="text-slate-500 text-[9px] md:text-xs">en Reynosa</p>
                            </div>
                        </div>
                        <div class="w-px h-8 md:h-10 bg-slate-100"></div>
                        <div class="flex flex-col sm:flex-row items-center text-center sm:text-left gap-1 sm:gap-3">
                            <div class="text-2xl md:text-4xl font-black text-warm-600">+{STATS.servicesCompleted}</div>
                            <div>
                                <p class="font-bold text-slate-900 text-[10px] md:text-sm leading-tight">Servicios</p>
                                <p class="text-slate-500 text-[9px] md:text-xs">completados</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Text Content -->
            <div class="order-1 lg:order-2">
                <span class="inline-block text-brand-600 font-semibold text-xs uppercase tracking-[0.2em] mb-3">Sobre Mí</span>
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-slate-900 mb-6 leading-tight">
                    Tu equipo en las <span class="text-brand-600">manos correctas</span>
                </h2>
                <p class="text-slate-600 text-lg leading-relaxed mb-8">
                    Soy Orlando, técnico de Reynosa. Empecé con mis herramientas y el compromiso de hacer las cosas bien hechas. Hoy, familias y negocios de toda la ciudad confían en mí para mantener sus equipos funcionando.
                </p>
                <p class="text-slate-500 mb-8 font-medium">
                    Mi objetivo es simple: darte un servicio honesto y con la garantía de que el trabajo queda bien hecho.
                </p>

                <!-- Trust points grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
                    {trustPoints.map(point => (
                        <div class="flex items-center gap-3 p-3 rounded-xl bg-slate-50 border border-slate-100 group transition-all duration-300 hover:shadow-md hover:border-brand-100 hover:bg-white">
                            <div class="w-8 h-8 rounded-lg bg-brand-50 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                                <svg class="w-4 h-4 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d={point.icon} />
                                </svg>
                            </div>
                            <span class="text-slate-700 text-sm font-medium">{point.text}</span>
                        </div>
                    ))}
                </div>

                <!-- CTA -->
                <a href={WHATSAPP.default} target="_blank" class="inline-flex items-center gap-3 px-8 py-4 bg-brand-500 hover:bg-brand-400 text-white font-bold rounded-xl transition-all duration-300 hover:-translate-y-1 shadow-lg shadow-brand-500/25">
                    Contactarme Ahora
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </a>
            </div>
        </div>
    </div>
</section>
