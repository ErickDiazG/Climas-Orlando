---
import { STATS } from '../config/site';
import { Image } from 'astro:assets';
import staffImg from '../../public/images/sobre-nosotros.webp';

const trustPoints = [
    "Técnico con más de " + STATS.yearsExperience + " años de experiencia",
    "Diagnóstico honesto",
    "Refacciones originales",
    "Garantía en cada trabajo",
    "Precios directos sin letra chica ni cargos sorpresa",
    "100% local",
];
---

<section id="sobre-nosotros" class="py-20 md:py-28 bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

            <!-- Image Side -->
            <div class="relative reveal order-2 lg:order-1">
                <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100">
                    <Image 
                        src={staffImg} 
                        alt="Orlando Diaz - Experto de Multiservicios Diaz en Reynosa" 
                        width={600}
                        height={700}
                        class="w-full h-[420px] lg:h-[520px] object-cover"
                        loading="lazy"
                    />
                </div>
                <!-- Experience badge — subtle, no floating cards -->
                <div class="absolute bottom-4 left-4 right-4 bg-slate-900/90 backdrop-blur-sm rounded-xl px-5 py-4 text-white">
                    <div class="flex items-center gap-3">
                        <div class="text-3xl font-black text-blue-400">+{STATS.yearsExperience}</div>
                        <div>
                            <p class="font-bold text-sm leading-tight">Años sirviendo</p>
                            <p class="text-slate-400 text-xs">a familias de Reynosa</p>
                        </div>
                        <div class="mx-3 w-px h-10 bg-slate-600"></div>
                        <div class="text-3xl font-black text-blue-400">+{STATS.servicesCompleted}</div>
                        <div>
                            <p class="font-bold text-sm leading-tight">Servicios</p>
                            <p class="text-slate-400 text-xs">completados</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Text Content -->
            <div class="reveal order-1 lg:order-2">
                <span class="inline-block text-blue-600 font-bold text-xs tracking-[0.2em] uppercase mb-3">Mi Experiencia</span>
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-slate-900 mb-4 leading-tight uppercase">
                    Tu equipo en manos de alguien que sabe lo que hace
                </h2>
                <p class="text-slate-600 text-base leading-relaxed mb-8">
                    Soy técnico de Reynosa. Empecé con mis herramientas y el compromiso de hacer las cosas bien hechas y hoy, familias y negocios confían en mí.
                </p>

                <!-- Checkmark list — Courtesy AC style -->
                <ul class="space-y-3 mb-8">
                    {trustPoints.map(point => (
                        <li class="flex items-start gap-3">
                            <div class="w-5 h-5 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0 mt-0.5">
                                <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                </svg>
                            </div>
                            <span class="text-slate-700 text-sm leading-relaxed">{point}</span>
                        </li>
                    ))}
                </ul>

                <!-- CTA -->
                <a href="#contacto" class="inline-flex items-center gap-2 px-7 py-3.5 bg-blue-700 hover:bg-blue-800 text-white font-bold rounded-lg transition-all duration-300 text-sm shadow-md hover:shadow-lg">
                    Contactame Ahora
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
                </a>
            </div>

        </div>
    </div>
</section>
