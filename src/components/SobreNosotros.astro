---
import { STATS } from '../config/site';
import { Image } from 'astro:assets';
import staffImg from '../../public/images/sobre-nosotros.webp';
---

<section id="sobre-nosotros" class="py-20 md:py-28 bg-gray-50 relative overflow-hidden">
    <!-- Decorative -->
    <div class="absolute bottom-0 right-0 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            <!-- Text Content -->
            <div class="reveal">
                <span class="inline-block text-blue-600 font-bold text-sm tracking-widest uppercase mb-3">Mi Experiencia</span>
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 mb-6 leading-tight">
                    Experiencia real para que tus equipos no vuelvan a fallar
                </h2>
                <div class="space-y-4 text-slate-600 text-[15px] leading-relaxed mb-8">
                    <p>
                        <strong class="text-slate-900">Soy técnico de aquí de Reynosa.</strong> Empecé con mis herramientas y el compromiso de hacer las cosas bien hechas, y me da mucho orgullo que hoy en día tantas familias y negocios confíen en mí.
                    </p>
                    <p>
                        Trato de ser lo más transparente posible: te digo qué tiene tu aparato, cuánto cuesta realmente y uso refacciones que aguanten para que no me tengas que llamar dos veces por lo mismo.
                    </p>
                </div>

                <!-- Core values as compact badges -->
                <div class="flex flex-wrap gap-3">
                    <span class="inline-flex items-center gap-2 px-4 py-2 bg-blue-50 border border-blue-100 text-blue-700 rounded-lg text-sm font-semibold">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg>
                        Trato Directo
                    </span>
                    <span class="inline-flex items-center gap-2 px-4 py-2 bg-green-50 border border-green-100 text-green-700 rounded-lg text-sm font-semibold">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
                        Capacitación Continua
                    </span>
                    <span class="inline-flex items-center gap-2 px-4 py-2 bg-amber-50 border border-amber-100 text-amber-700 rounded-lg text-sm font-semibold">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                        100% Local
                    </span>
                </div>
            </div>

            <!-- Image Side -->
            <div class="relative reveal-right">
                <div class="rounded-3xl overflow-hidden shadow-xl border border-gray-200">
                    <Image 
                        src={staffImg} 
                        alt="Orlando Diaz - Experto de Multiservicios Diaz en Reynosa" 
                        width={600}
                        height={800}
                        class="w-full h-[400px] lg:h-[500px] object-cover"
                        loading="lazy"
                    />
                </div>
                <!-- Floating stat card -->
                <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-5 border border-gray-100 hidden md:block">
                    <div class="text-3xl font-extrabold text-blue-600 leading-none">+{STATS.servicesCompleted}</div>
                    <p class="text-slate-600 text-sm mt-1">Servicios realizados</p>
                </div>
                <div class="absolute -top-4 -right-4 bg-white rounded-2xl shadow-xl p-5 border border-gray-100 hidden md:block">
                    <div class="text-3xl font-extrabold text-green-600 leading-none">+{STATS.yearsExperience}</div>
                    <p class="text-slate-600 text-sm mt-1">Años de experiencia</p>
                </div>
            </div>
        </div>
    </div>
</section>
