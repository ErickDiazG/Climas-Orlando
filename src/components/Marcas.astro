---
const brandGroups = [
    {
        category: "Climatización",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>`,
        color: "blue",
        brands: ["Mirage"]
    },
    {
        category: "Línea Blanca (Lavadoras)",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.83-5.83M15.17 11.42a4 4 0 11-5.66-5.66 4 4 0 015.66 5.66zM5.5 8.5L2 12m0 0l3.5 3.5M2 12h14" /></svg>`,
        color: "green",
        brands: ["Whirlpool", "KitchenAid", "Amana", "Kenmore", "Roper", "Estate"]
    }
];

const colorMap: Record<string, { pill: string; badge: string }> = {
    blue: {
        pill: "bg-blue-50 text-blue-700 border border-blue-100 hover:bg-blue-100",
        badge: "bg-blue-100 text-blue-600",
    },
    green: {
        pill: "bg-green-50 text-green-700 border border-green-100 hover:bg-green-100",
        badge: "bg-green-100 text-green-600",
    }
};
---

<section class="py-16 md:py-20 bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Header -->
        <div class="text-center mb-12 reveal">
            <span class="inline-block text-blue-600 font-bold text-sm tracking-widest uppercase mb-3">Experiencia comprobada</span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-3">
                Marcas que manejamos
            </h2>
            <p class="text-slate-500 text-base max-w-xl mx-auto">
                Trabajo con las marcas más confiables del mercado. Si tu equipo es de alguna de estas, estás en buenas manos.
            </p>
        </div>

        <!-- Brand Groups Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto reveal">
            {brandGroups.map(group => {
                const colors = colorMap[group.color];
                return (
                    <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
                        <div class="flex items-center gap-3 mb-5">
                            <div class={`w-9 h-9 rounded-xl ${colors.badge} flex items-center justify-center flex-shrink-0`}>
                                <Fragment set:html={group.icon} />
                            </div>
                            <h3 class="font-extrabold text-slate-800 text-base">{group.category}</h3>
                        </div>
                        <div class="flex flex-wrap gap-2.5">
                            {group.brands.map(brand => (
                                <span class={`px-3.5 py-1.5 rounded-full text-sm font-semibold cursor-default transition-colors duration-200 ${colors.pill}`}>
                                    {brand}
                                </span>
                            ))}
                        </div>
                    </div>
                );
            })}
        </div>

        <p class="text-center text-slate-400 text-xs mt-8 reveal">
            ¿Tu equipo es de otra marca? Contáctame, es probable que también pueda ayudarte.
        </p>

    </div>
</section>
