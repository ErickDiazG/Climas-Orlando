---
import { WHATSAPP } from '../config/site';
import { Image } from 'astro:assets';
import servicesImg from '../../public/images/foto servicios.webp';

const leftServices = [
    {
        title: "Venta e Instalación de Minisplit",
        description: "Equipo Mirage con instalación profesional incluida y garantía de 3 meses.",
        ctaText: "Cotizar ahora",
        ctaLink: WHATSAPP.ventaEquipos,
        icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.999 2.999 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.999 2.999 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" /></svg>`,
    },
    {
        title: "Mantenimiento de Clima",
        description: "Preventivo: Limpieza profunda de evaporador, revisión de presiones de gas y limpieza de filtros. Correctivo: diagnóstico y reparación.",
        ctaText: "Agendar servicio",
        ctaLink: WHATSAPP.mantenimientoPreventivo,
        icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.83-5.83M15.17 11.42a4 4 0 11-5.66-5.66 4 4 0 015.66 5.66zM5.5 8.5L2 12m0 0l3.5 3.5M2 12h14" /></svg>`,
    },
    {
        title: "Carga de Gas Refrigerante",
        description: "Recarga de gas R-22 o R-410A. Si tu equipo ya no enfría como antes, puede ser fuga de gas.",
        ctaText: "Consultar precio",
        ctaLink: WHATSAPP.cargaDeGas,
        icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" /></svg>`,
    },
];

const rightServices = [
    {
        title: "Reubicación de Minisplit",
        description: "Desmontamos tu equipo y lo reinstalamos en el nuevo lugar.",
        ctaText: "Solicitar cotización",
        ctaLink: WHATSAPP.reubicacionMinisplit,
        icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>`,
    },
    {
        title: "Venta de Lavadoras",
        description: "Lavadoras seminuevas del ecosistema Whirlpool: KitchenAid, Amana, Kenmore, Roper y Estate.",
        ctaText: "Ver disponibilidad",
        ctaLink: WHATSAPP.ventaLavadoras,
        icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.999 2.999 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.999 2.999 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" /></svg>`,
    },
    {
        title: "Mantenimiento de Lavadora",
        description: "Preventivo: limpieza interna, revisión de motor y bomba. Correctivo: ¿no centrifuga, no desagua o vibra mucho? Diagnóstico y reparación.",
        ctaText: "Agendar servicio",
        ctaLink: WHATSAPP.mantenimientoLavadoraPreventivo,
        icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.746 3.746 0 0 1 21 12Z" /></svg>`,
    },
];
---

<section id="servicios" class="py-16 md:py-24 bg-gray-50 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Section Header -->
        <div class="text-center mb-12 reveal">
            <span class="inline-block text-blue-600 font-bold text-xs tracking-[0.2em] uppercase mb-3">Lo que hacemos</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-slate-900 uppercase leading-tight">
                Nuestros Servicios
            </h2>
        </div>

        <!-- Bento Grid: Left cards | Center photo | Right cards -->
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_400px_1fr] gap-6">

            <!-- Left column — AC Services -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-6">
                {leftServices.map(service => (
                    <div class="bg-white hover:shadow-lg transition-all duration-300 rounded-3xl py-10 px-8 flex flex-col gap-6 shadow-sm border border-slate-100 hover:border-blue-200 group">
                        <div class="text-blue-600">
                            <Fragment set:html={service.icon.replace('w-8 h-8', 'w-12 h-12')} />
                        </div>
                        <div class="flex-1">
                            <h3 class="text-slate-900 font-black text-xl leading-snug uppercase mb-3 tracking-tight">{service.title}</h3>
                            <p class="text-slate-500 text-sm leading-relaxed">{service.description}</p>
                        </div>
                        <a href={service.ctaLink} target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm rounded-lg shadow-sm transition-all duration-200 self-start uppercase tracking-wider">
                            {service.ctaText}
                        </a>
                    </div>
                ))}
            </div>

            <!-- Center — Photo of technician with overlay -->
            <div class="hidden lg:flex rounded-3xl overflow-hidden relative shadow-lg">
                <!-- Photo -->
                <Image
                    src={servicesImg}
                    alt="Servicios Diaz - Nuestro experto trabajando"
                    width={450}
                    height={1000}
                    class="w-full h-full object-cover object-top"
                    loading="lazy"
                />
            </div>

            <!-- Right column — Washer Services -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-6">
                {rightServices.map(service => (
                    <div class="bg-white hover:shadow-lg transition-all duration-300 rounded-3xl py-10 px-8 flex flex-col gap-6 shadow-sm border border-slate-100 hover:border-blue-200 group">
                        <div class="text-blue-600">
                            <Fragment set:html={service.icon.replace('w-8 h-8', 'w-12 h-12')} />
                        </div>
                        <div class="flex-1">
                            <h3 class="text-slate-900 font-black text-xl leading-snug uppercase mb-3 tracking-tight">{service.title}</h3>
                            <p class="text-slate-500 text-sm leading-relaxed">{service.description}</p>
                        </div>
                        <a href={service.ctaLink} target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm rounded-lg shadow-sm transition-all duration-200 self-start uppercase tracking-wider">
                            {service.ctaText}
                        </a>
                    </div>
                ))}
            </div>

        </div>

    </div>
</section>
