---
import { WHATSAPP } from '../config/site';
import { Image } from 'astro:assets';
import minisplitImg from '../../public/images/minisplit caja.webp';
import lavadoraImg from '../../public/images/lavadora.webp';

const minisplitServices = [
    {
        title: "Venta e Instalación",
        description: "Equipo Mirage nuevo. Instalación profesional incluida y garantía directa de 3 meses.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`,
        link: WHATSAPP.ventaEquipos,
        color: "brand"
    },
    {
        title: "Mantenimiento",
        description: "Preventivo: Limpieza profunda y filtros. Correctivo: Diagnóstico y reparación integral.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.673.337a4 4 0 01-2.506.326l-1.866-.373a5 5 0 00-3.108.377l-.508.254a1 1 0 00-.42 1.174l.113.453a1 1 0 00.97.758h10.82a1 1 0 00.974-.768l.212-.848a1 1 0 00-.424-1.127z" /></svg>`,
        link: WHATSAPP.mantenimientoPreventivo,
        color: "warm"
    },
    {
        title: "Carga de Gas",
        description: "Recarga experta de R-22 o R-410A. ¿Ya no enfría? Detectamos y eliminamos fugas.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
        link: WHATSAPP.cargaDeGas,
        color: "brand"
    },
    {
        title: "Reubicación",
        description: "Desmontamos tu equipo con cuidado y lo reinstalamos en su nueva ubicación.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
        link: WHATSAPP.reubicacionMinisplit,
        color: "warm"
    }
];

const washerServices = [
    {
        title: "Venta de Seminuevas",
        description: "Equipo Whirlpool, KitchenAid, Amana y más. Calidad garantizada.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>`,
        link: WHATSAPP.ventaLavadoras,
    },
    {
        title: "Mantenimiento",
        description: "Limpieza profunda, revisión de motor y bomba para alargar su vida útil.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /></svg>`,
        link: WHATSAPP.mantenimientoLavadoraPreventivo,
    },
    {
        title: "Reparación",
        description: "¿No centrifuga, no desagua o vibra mucho? Diagnóstico y reparación inmediata.",
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.83-5.83M15.17 11.42a4 4 0 11-5.66-5.66 4 4 0 015.66 5.66zM5.5 8.5L2 12m0 0l3.5 3.5M2 12h14" /></svg>`,
        link: WHATSAPP.mantenimientoLavadoraCorrectivo,
    }
];
---

<section id="servicios" class="overflow-hidden">
    <!-- Minisplit Services -->
    <div class="bg-dark-950 py-20 lg:py-28">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Header -->
            <div class="text-center mb-16">
                <span class="inline-block text-brand-400 font-semibold text-xs uppercase tracking-[0.2em] mb-3">Servicios</span>
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-4">
                    Climatización
                </h2>
                <p class="text-slate-400 max-w-2xl mx-auto text-lg">
                    Mantenemos tu hogar fresco con servicio profesional y garantía en cada trabajo.
                </p>
            </div>

            <!-- Service Cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                {minisplitServices.map((service) => (
                    <a href={service.link} target="_blank" class="group relative bg-white/5 border border-white/10 rounded-2xl p-6 transition-all duration-300 hover:bg-white hover:border-transparent hover:shadow-2xl hover:shadow-brand-500/10 hover:-translate-y-2">
                        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-brand-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="relative z-10 h-full flex flex-col">
                            <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-4 transition-colors ${
                                service.color === 'brand' 
                                ? 'bg-brand-500/20 text-brand-400 group-hover:bg-brand-500 group-hover:text-white' 
                                : 'bg-warm-500/20 text-warm-400 group-hover:bg-warm-500 group-hover:text-white'
                            }`}>
                                <Fragment set:html={service.icon} />
                            </div>
                            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-brand-400 transition-colors">{service.title}</h3>
                            <p class="text-slate-400 text-sm leading-relaxed mb-4 flex-1">
                                {service.description}
                            </p>
                            
                            <!-- New CTA Button/Arrow -->
                            <div class="flex items-center gap-2 text-brand-400 font-bold text-sm opacity-100 translate-y-0 lg:opacity-0 lg:group-hover:opacity-100 lg:translate-y-2 lg:group-hover:translate-y-0 transition-all duration-300">
                                <span>Solicitar</span>
                                <svg class="w-4 h-4 translate-x-1 lg:translate-x-0 lg:group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </div>

    <!-- Washer Services -->
    <div class="bg-white py-20 lg:py-28 relative overflow-hidden">
        <!-- Background decoration -->
        <div class="absolute top-0 right-0 w-1/2 h-full bg-slate-50/50 blur-[100px] pointer-events-none"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
                <!-- Left: Content -->
                <div>
                    <span class="inline-block text-warm-500 font-semibold text-xs uppercase tracking-[0.2em] mb-3">Especialista</span>
                    <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-slate-900 mb-4">
                        Línea Blanca
                    </h2>
                    <p class="text-slate-600 text-lg mb-8 leading-relaxed">
                        ¿Tu lavadora no funciona?.Te ayudamos con marcas como Whirlpool, KitchenAid, Amana, Kenmore y más.
                    </p>

                    <!-- Service list -->
                    <div class="space-y-4">
                        {washerServices.map((service) => (
                            <a href={service.link} target="_blank" class="group flex items-center gap-4 p-4 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
                                <div class="w-12 h-12 rounded-xl bg-warm-500/10 flex items-center justify-center text-warm-500 group-hover:bg-warm-500 group-hover:text-white transition-colors">
                                    <Fragment set:html={service.icon} />
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-slate-900 group-hover:text-warm-600 transition-colors">{service.title}</h4>
                                    <p class="text-slate-500 text-sm">{service.description}</p>
                                </div>
                                <svg class="w-5 h-5 text-slate-400 group-hover:text-warm-500 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                            </a>
                        ))}
                    </div>
                </div>

                <!-- Right: Image -->
                <div class="relative">
                    <div class="relative rounded-3xl overflow-hidden shadow-2xl">
                        <Image 
                            src={lavadoraImg}
                            alt="Reparación de lavadoras"
                            width={600}
                            height={500}
                            class="w-full h-auto object-cover"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>

                    </div>
                    <!-- Floating badge -->
                    <div class="absolute -top-4 -right-4 bg-warm-500 text-white px-4 py-2 rounded-xl font-bold text-sm shadow-lg animate-float">
                        Whirlpool
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
