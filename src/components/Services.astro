---
import ServiceCard from './ServiceCard.astro';
import { WHATSAPP } from '../config/site';

const services = [
    {
        title: "Venta de Equipos Mirage",
        description: "Minisplits de alta eficiencia con instalación incluida.",
        imageSrc: "/images/minisplit caja.webp",
        imageAlt: "Minisplit moderno y eficiente instalado en pared",
        features: ["Garantía", "Instalación básica incluida"],
        ctaText: "Cotizar equipo",
        ctaLink: WHATSAPP.ventaEquipos,
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.999 2.999 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.999 2.999 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" /></svg>'
    },
    {
        title: "Reparación de Lavadoras",
        description: "Diagnóstico y reparación con refacciones originales Whirlpool.",
        imageSrc: "/images/lavadora.webp",
        imageAlt: "Lavadora Whirlpool en proceso de reparación profesional",
        features: ["Refacciones originales", "Servicio el mismo día"],
        ctaText: "Agendar revisión",
        ctaLink: WHATSAPP.reparacionLavadoras,
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.83-5.83M15.17 11.42a4 4 0 11-5.66-5.66 4 4 0 015.66 5.66zM5.5 8.5L2 12m0 0l3.5 3.5M2 12h14" /></svg>',
        imageClass: "object-top"
    },
    {
        title: "Mantenimiento de Climas",
        description: "Limpieza profunda de evaporador, revisión de presiones de gas y limpieza de filtros.",
        imageSrc: "/images/orlando-trabajando.webp",
        imageAlt: "Técnico realizando mantenimiento profesional de minisplit",
        features: ["Limpieza profunda", "Revisión completa del sistema"],
        ctaText: "Solicitar servicio",
        ctaLink: WHATSAPP.mantenimientoClimas,
        icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>'
    }
];
---

<section id="servicios" class="py-20 md:py-28 bg-white relative border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16 reveal">
            <span class="inline-block text-blue-600 font-bold text-sm tracking-widest uppercase mb-3">Mis Servicios</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 mb-4">
                ¿En qué puedo ayudarte hoy?
            </h2>
            <p class="text-slate-600 text-lg max-w-2xl mx-auto">
                Soluciones profesionales de climatización y línea blanca para tu hogar o negocio.
            </p>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10 reveal-stagger">
            {services.map(service => (
                <ServiceCard {...service} />
            ))}
        </div>
    </div>
</section>
