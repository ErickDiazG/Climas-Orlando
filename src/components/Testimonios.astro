---
const testimonials = [
    {
        name: "María García",
        role: "Ama de casa · Col. Las Fuentes",
        text: "Excelente servicio. Mi minisplit tenía fuga de gas y el técnico llegó el mismo día. Quedó como nuevo y me dieron garantía por escrito. Totalmente recomendados.",
        rating: 5,
        initials: "MG",
    },
    {
        name: "Roberto Martínez",
        role: "Negocio local · Centro de Reynosa",
        text: "Les compré 3 minisplits Mirage para mi local. La instalación fue rápida y profesional. Llevan 2 años funcionando perfecto. El precio fue muy justo.",
        rating: 5,
        initials: "RM",
    },
    {
        name: "Laura Hernández",
        role: "Ama de casa · Col. Moderno",
        text: "Mi lavadora Whirlpool dejó de centrifugar y pensé que ya no tenía arreglo. Diaz la revisó, cambió la pieza y quedó funcionando perfecto. Muy honesto en su diagnóstico.",
        rating: 5,
        initials: "LH",
    },
    {
        name: "Carlos Ramírez",
        role: "Oficina · Zona Industrial",
        text: "Contraté el mantenimiento preventivo para los 5 climas de mi oficina. Servicio puntual, limpieza profunda y precios accesibles. Ya son nuestro proveedor fijo.",
        rating: 5,
        initials: "CR",
    },
];
---

<section class="py-20 md:py-28 bg-white relative overflow-hidden">
    <!-- Decorative -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-50 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Section Header -->
        <div class="text-center mb-16 reveal">
            <span class="inline-block text-blue-600 font-bold text-sm tracking-widest uppercase mb-3">Testimonios</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 mb-4">
                Lo que dicen nuestros clientes
            </h2>
            <p class="text-gray-500 text-lg max-w-2xl mx-auto">
                La satisfacción de nuestros clientes es nuestra mejor carta de presentación.
            </p>
        </div>

        <!-- Testimonials Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 reveal-stagger">
            {testimonials.map(t => (
                <div class="bg-gray-50 border border-gray-100 rounded-2xl p-8 hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-1 transition-all duration-500 group">
                    <!-- Stars -->
                    <div class="flex gap-1 mb-4">
                        {Array.from({ length: t.rating }).map(() => (
                            <svg class="w-5 h-5 text-yellow-400" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" /></svg>
                        ))}
                    </div>

                    <!-- Quote -->
                    <p class="text-gray-600 leading-relaxed mb-6 text-[15px]">
                        "{t.text}"
                    </p>

                    <!-- Author -->
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-slate-800 to-slate-900 flex items-center justify-center text-white font-bold text-sm shadow-lg shadow-slate-500/20">
                            {t.initials}
                        </div>
                        <div>
                            <p class="font-bold text-gray-900 text-sm">{t.name}</p>
                            <p class="text-gray-400 text-xs">{t.role}</p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
