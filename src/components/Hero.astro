---
import { WHATSAPP, CONTACT } from '../config/site';
import { Image } from 'astro:assets';
import heroImg from '../../public/images/hero.webp';
import logoImg from '../../public/images/Logo SD.webp';

const benefits = [
    { icon: "✓", text: "Diagnóstico honesto" },
    { icon: "✓", text: "Garantía" },
    { icon: "✓", text: "Servicio a domicilio" },
];

const brands = [
    "SAMSUNG", "TRANE", "LG", "KITCHENAID", "AMANA", "KENMORE", "PRIME", "MIRAGE", "YORK", "WHIRLPOOL"
];

const serviceCards = [
    { title: "MANTENIMIENTO", desc: "Preventivo y Correctivo", icon: "ticket" },
    { title: "INSTALACIÓN", desc: "Equipos de Alta Eficiencia", icon: "ticket" },
    { title: "LAVADORAS", desc: "Reparación Multimarca", icon: "ticket" },
];
---

<style>
    @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-infinite-scroll {
        animation: scroll 15s linear infinite;
    }
    @media (min-width: 1024px) {
        .animate-infinite-scroll {
            animation-duration: 30s;
        }
    }
    @keyframes float-particle {
        0% { transform: translateY(0) translateX(0) scale(0.5); opacity: 0; }
        20% { opacity: 0.6; }
        80% { opacity: 0.6; }
        100% { transform: translateY(70vh) translateX(150px) scale(1.5); opacity: 0; }
    }
    .particle {
        position: absolute;
        top: 15%; /* Starting point near the AC */
        left: 35%; /* Starting point near the AC */
        background: radial-gradient(circle, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0.2) 50%, rgba(255,255,255,0) 80%);
        border-radius: 50%;
        pointer-events: none;
        animation: float-particle linear infinite;
    }
</style>

<section id="inicio" class="relative min-h-screen lg:min-h-screen flex flex-col overflow-hidden bg-navy-950">
    <!-- Background with overlay -->
    <div class="absolute inset-0">
        <Image
            src={heroImg}
            alt="Técnico de Servicios Diaz realizando mantenimiento de clima"
            width={1920}
            height={1080}
            class="w-full h-full object-cover object-[25%_center] lg:object-center"
            fetchpriority="high"
            loading="eager"
            decoding="sync"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#0a0f1e]/80 via-[#0a0f1e]/40 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/40"></div>
    </div>

    <!-- Particles Container -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        {Array(30).fill(0).map((_, i) => (
            <div 
                class="particle" 
                style={{
                    left: `${30 + Math.random() * 20}%`, /* Spread around the AC area */
                    top: `${12 + Math.random() * 8}%`, /* Spread around the AC area */
                    width: `${Math.random() * 12 + 6}px`,
                    height: `${Math.random() * 12 + 6}px`,
                    animationDuration: `${Math.random() * 8 + 10}s`,
                    animationDelay: `${Math.random() * 15}s`,
                    opacity: '0',
                    filter: `blur(${Math.random() * 2 + 1}px)`
                }}
            />
        ))}
    </div>

    <!-- Decorative elements -->
    <div class="absolute top-20 right-10 w-72 h-72 bg-brand-500/20 rounded-full blur-[100px] animate-blob"></div>
    <div class="absolute bottom-20 left-1/4 w-96 h-96 bg-warm-500/10 rounded-full blur-[120px] animate-blob" style="animation-delay: 2s;"></div>

    <!-- Main Content -->
    <div class="relative z-10 flex-1 flex flex-col justify-center max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 w-full">
        <div class="flex flex-col items-center text-center lg:items-start lg:text-left w-full max-w-4xl">
            <!-- Sub-headline -->
            <span class="text-brand-400 font-bold text-[10px] md:text-sm tracking-[0.2em] uppercase mb-4 drop-shadow-sm">
                MINISPLITS Y LAVADORAS · ATENCIÓN A DOMICILIO
            </span>
            <!-- Headline -->
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white leading-[0.95] tracking-tighter drop-shadow-2xl mb-8">
                <span class="block text-white">¿Calor en tu hogar?</span>
                <span class="block text-brand-500">Deja que lo</span>
                <span class="block text-white">resolvamos.</span>
            </h1>
            
            <p class="text-base md:text-xl text-white/90 max-w-2xl font-medium drop-shadow-md mb-10 leading-relaxed">
                Reparación, mantenimiento e instalación de climas y lavadoras en tu hogar. <br class="hidden sm:block" /> 
                <span class="text-white font-bold underline decoration-brand-500/50 underline-offset-4">Un servicio honesto, directo y sin complicaciones.</span>
            </p>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row items-center lg:items-start gap-4 w-full sm:w-auto">
                <!-- WhatsApp Button -->
                <a href={WHATSAPP.default} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#25D366] hover:bg-[#20ba5a] text-white font-black rounded-2xl text-base shadow-lg shadow-[#25D366]/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl w-full sm:w-auto">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                    WhatsApp
                </a>

                <!-- Call Button -->
                <a href={`tel:${CONTACT.phone.replace(/\s+/g, '')}`} 
                   class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-black/20 hover:bg-black/40 text-white font-bold rounded-2xl text-base border border-white/20 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 w-full sm:w-auto">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    Llamar Ahora
                </a>
            </div>
        </div>
    </div>

    <!-- Brands strip -->
    <div class="relative z-10 w-full bg-black/40 backdrop-blur-md border-t border-white/5 py-2 lg:py-3 overflow-hidden mt-auto">
        <div class="flex min-w-full overflow-hidden">
            <div class="flex animate-infinite-scroll whitespace-nowrap min-w-full items-center shrink-0">
                <!-- Two copies of the brand list for seamless looping -->
                {Array(2).fill(0).map(() => (
                    <div class="flex items-center shrink-0">
                        {brands.map((brand, index) => (
                            <div class="flex items-center gap-6 md:gap-12 px-6 md:px-12">
                                <span class="text-white/60 font-bold text-[10px] md:text-xs tracking-[0.2em] uppercase">
                                    {brand}
                                </span>
                                {index === 6 && (
                                    <span class="text-brand-400 italic font-bold text-[10px] md:text-xs tracking-widest px-4 uppercase shrink-0">
                                        TRABAJAMOS CON
                                    </span>
                                )}
                                <span class="text-white/20 font-light text-xl">/</span>
                            </div>
                        ))}
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
