---
import { WHATSAPP } from '../config/site';
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Background Image (Occupies full height for transparent navbar) -->
    <div class="absolute inset-0 bg-gray-50">
        <img
            src="/images/hero.webp"
            alt="Minisplit premium moderno estilo Apple"
            class="w-full h-full object-cover object-[center_35%]"
            fetchpriority="high"
            loading="eager"
            decoding="sync"
        />
        <!-- Slightly stronger tint for better legibility on transparent header -->
        <div class="absolute inset-0 bg-slate-900/20 md:bg-slate-900/10 transition-colors duration-500" id="hero-overlay"></div>
    </div>

    <!-- Content. We add more padding-top to push the card down, revealing the minisplit -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 md:pt-40 pb-6 w-full">
        <!-- Glassmorphism Card Container -->
        <div class="max-w-xl bg-white/40 backdrop-blur-xl border border-white/40 p-5 sm:p-6 md:p-8 rounded-[2rem] shadow-[0_20px_50px_rgba(8,112,184,0.07)] animate-fade-in-up">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-white/90 border border-blue-100 rounded-full px-3 py-1.5 mb-5 shadow-sm">
                <span class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-pulse"></span>
                <span class="text-blue-700 text-xs font-bold tracking-wide uppercase">Disponibilidad Inmediata</span>
            </div>

            <!-- Title -->
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 leading-[1.1] mb-4 drop-shadow-sm tracking-tight">
                ¿Calor en Reynosa?<br/>
                <span class="text-blue-600">Deja que lo resolvamos.</span>
            </h1>

            <!-- Subtitle -->
            <p class="text-sm md:text-base text-slate-700 mb-6 font-medium">
                Reparación y mantenimiento de climas y línea blanca. Un servicio honesto, directo y sin complicaciones para tu hogar.
            </p>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-3 mb-6">
                <a href={WHATSAPP.default} target="_blank" class="px-5 py-3 bg-green-500 hover:bg-green-600 text-white font-bold rounded-xl shadow-lg shadow-green-500/30 transition-all duration-300 transform hover:-translate-y-0.5 hover:shadow-xl flex items-center justify-center gap-2 text-sm md:text-base">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                    Contactar
                </a>
                <a href="#servicios" class="px-5 py-3 border-2 border-slate-300 hover:border-blue-500 bg-white/60 hover:bg-white/90 text-slate-700 hover:text-blue-700 font-bold rounded-xl transition-all duration-300 transform hover:-translate-y-0.5 shadow-sm flex items-center justify-center gap-2 text-sm md:text-base">
                    Ver Servicios
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
                </a>
            </div>

            <!-- BIG Trust Badges -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 mt-6 pt-6 border-t border-slate-200/50">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-green-100/80 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.746 3.746 0 0 1 21 12Z" /></svg>
                    </div>
                    <div>
                        <p class="text-slate-900 font-bold text-sm leading-tight">Garantía</p>
                        <p class="text-slate-700 font-medium text-xs">En cada trabajo</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-blue-100/80 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                    </div>
                    <div>
                        <p class="text-slate-900 font-bold text-sm leading-tight">Atención</p>
                        <p class="text-slate-700 font-medium text-xs">Rápida</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-amber-100/80 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
                    </div>
                    <div>
                        <p class="text-slate-900 font-bold text-sm leading-tight">Trato</p>
                        <p class="text-slate-700 font-medium text-xs">Directo</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Subtle section transition -->
    <div class="absolute bottom-[-1px] left-0 w-full overflow-hidden leading-none z-10">
        <svg viewBox="0 0 1200 60" preserveAspectRatio="none" class="relative block w-full h-[24px] md:h-[40px]">
            <path d="M0,30 C300,55 900,5 1200,30 L1200,60 L0,60 Z" fill="#f8fafc"></path>
        </svg>
    </div>
</section>
