---
import { WHATSAPP, CONTACT } from '../config/site';
import { Image } from 'astro:assets';
import heroImg from '../../public/images/hero.webp';

---

<section id="inicio" class="relative min-h-screen flex flex-col overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
        <Image
            src={heroImg}
            alt="Técnico de Servicios Diaz realizando mantenimiento de clima"
            width={1920}
            height={1080}
            class="w-full h-full object-cover object-center"
            fetchpriority="high"
            loading="eager"
            decoding="sync"
        />
        <!-- Strong gradient overlay — left-heavy so text is readable, right side shows the image -->
        <div class="absolute inset-0 bg-gradient-to-r from-slate-900/85 via-slate-900/60 to-slate-900/20"></div>
        <!-- Very subtle bottom fade to white for the transition into Services -->
        <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white/10 to-transparent"></div>
    </div>

    <!-- Content: vertically centered, pushed away from nav -->
    <div class="relative z-10 flex-1 flex flex-col justify-center max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-12 w-full">
        <!-- Tag line -->
        <p class="text-blue-400 font-bold text-xs sm:text-sm uppercase tracking-[0.25em] mb-4 animate-fade-in-up">
            Reynosa, Tamaulipas · Servicio a domicilio
        </p>

        <!-- Main Headline — Call-to-Value, conversational -->
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white leading-[1.08] tracking-tight mb-5 max-w-3xl animate-fade-in-up" style="animation-delay: 100ms;">
            ¿Calor en Reynosa?<br/>
            <span class="text-blue-500">Deja que lo</span><br/>
            resolvamos.
        </h1>

        <!-- Subtitle -->
        <p class="text-slate-300 text-base sm:text-lg max-w-xl mb-10 leading-relaxed animate-fade-in-up font-medium" style="animation-delay: 200ms;">
            Reparación, mantenimiento e instalación de climas y lavadoras en tu hogar. Un servicio honesto, directo y sin complicaciones.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up" style="animation-delay: 300ms;">
            <a href={WHATSAPP.default} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-green-500 hover:bg-green-400 text-white font-extrabold rounded-xl text-base shadow-lg shadow-green-900/40 transition-all duration-300 hover:-translate-y-0.5">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                WhatsApp
            </a>
            <a href={`tel:${CONTACT.phone}`}
               class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-bold rounded-xl text-base border border-white/30 transition-all duration-300 hover:-translate-y-0.5 backdrop-blur-sm">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.25-3.95-6.847-6.847l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
                Llamar Ahora
            </a>
        </div>
    </div>

    <!-- Bottom Dual Marquee — Brands strip (Refined & Slim) -->
    <div class="relative z-10 w-full bg-slate-900/95 backdrop-blur-sm border-t border-white/10 pt-6 pb-5">
        <!-- Main Label floating top -->
        <div class="absolute left-1/2 -top-3 -translate-x-1/2 z-30">
            <span class="bg-blue-600 text-white text-[9px] font-bold uppercase tracking-[0.25em] px-4 py-1 rounded-full shadow-lg border border-blue-500/30">
                Trabajamos con
            </span>
        </div>

        <!-- Row 1: Minisplits -->
        <div class="mb-1">
            <div class="text-center mb-1.5">
                <span class="text-[8px] font-bold text-blue-400/70 uppercase tracking-[0.3em]">Minisplits</span>
            </div>
            <div class="overflow-hidden relative w-full">
                <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-slate-900 to-transparent z-10"></div>
                <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-slate-900 to-transparent z-10"></div>
                <div class="marquee-ac flex gap-8 items-center whitespace-nowrap w-max">
                    {[...Array(3)].map(() => (
                        <>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">Mirage</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">York</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">Prime</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">Trane</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">LG</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">Samsung</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                        </>
                    ))}
                </div>
            </div>
        </div>

        <!-- Divider -->
        <div class="w-16 h-px bg-white/10 mx-auto my-2"></div>

        <!-- Row 2: Línea Blanca (Opposite direction) -->
        <div>
            <div class="text-center mb-1.5">
                <span class="text-[8px] font-bold text-slate-500/70 uppercase tracking-[0.3em]">Línea Blanca</span>
            </div>
            <div class="overflow-hidden relative w-full">
                <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-slate-900 to-transparent z-10"></div>
                <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-slate-900 to-transparent z-10"></div>
                <div class="marquee-laundry flex gap-8 items-center whitespace-nowrap w-max">
                    {[...Array(3)].map(() => (
                        <>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">Whirlpool</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">KitchenAid</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">Amana</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">Kenmore</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">Roper</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                            <span class="text-white/70 font-semibold text-xs tracking-widest hover:text-white transition-colors cursor-default uppercase">Estate</span>
                            <span class="text-blue-500/30 text-[8px]">·</span>
                        </>
                    ))}
                </div>
            </div>
        </div>
    </div>

    <style>
        .marquee-ac {
            animation: scroll-left 40s linear infinite;
        }
        .marquee-laundry {
            animation: scroll-right 45s linear infinite;
        }
        .marquee-ac:hover, .marquee-laundry:hover {
            animation-play-state: paused;
        }
        @keyframes scroll-left {
            from { transform: translateX(0); }
            to { transform: translateX(-33.333%); }
        }
        @keyframes scroll-right {
            from { transform: translateX(-33.333%); }
            to { transform: translateX(0); }
        }
    </style>
</section>
