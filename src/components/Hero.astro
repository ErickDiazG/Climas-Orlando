---
import { WHATSAPP } from '../config/site';
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
        <img
            src="/images/tecnico.webp"
            alt="Técnico profesional de Climas Orlando"
            class="w-full h-full object-cover"
        />
        <!-- Dark gradient overlay for text readability -->
        <div class="absolute inset-0 bg-gradient-to-r from-gray-900/85 via-gray-900/70 to-gray-900/40"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-20 w-full">
        <div class="max-w-2xl">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-green-500/15 border border-green-500/30 rounded-full px-4 py-1.5 mb-8 animate-fade-in">
                <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
                <span class="text-green-300 text-sm font-semibold tracking-wide uppercase">Disponibilidad Inmediata</span>
            </div>

            <!-- Title -->
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 animate-fade-in-up">
                ¿Calor en Reynosa?
                <span class="block text-green-400">Soluciones Inmediatas.</span>
            </h1>

            <!-- Subtitle — 1 line, concise -->
            <p class="text-lg md:text-xl text-gray-300 mb-10 animate-fade-in-up max-w-xl" style="animation-delay: 200ms;">
                Expertos en climatización y línea blanca. Servicio rápido, profesional y garantizado.
            </p>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-4 mb-12 animate-fade-in-up" style="animation-delay: 400ms;">
                <a href={WHATSAPP.default} target="_blank" class="px-8 py-4 bg-green-500 hover:bg-green-400 text-white font-bold rounded-xl shadow-lg shadow-green-500/30 transition-all duration-300 transform hover:-translate-y-0.5 hover:shadow-xl flex items-center justify-center gap-3 text-lg">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                    Cotizar por WhatsApp
                </a>
                <a href="#servicios" class="px-8 py-4 border-2 border-white/40 hover:border-white/70 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl transition-all duration-300 transform hover:-translate-y-0.5 backdrop-blur-sm flex items-center justify-center gap-2 text-lg">
                    Ver Nuestros Servicios
                    <span class="material-icons-outlined text-sm">arrow_forward</span>
                </a>
            </div>

            <!-- BIG Trust Badges — 3 prominent blocks -->
            <div class="grid grid-cols-3 gap-3 sm:gap-5 animate-fade-in" style="animation-delay: 700ms;">
                <div class="flex flex-col items-center sm:items-start sm:flex-row gap-2 sm:gap-3 bg-white/10 backdrop-blur-sm border border-white/10 rounded-xl px-3 sm:px-5 py-3 sm:py-4">
                    <div class="w-10 h-10 rounded-lg bg-green-500/20 flex items-center justify-center flex-shrink-0">
                        <span class="material-icons-outlined text-green-400 text-xl">verified</span>
                    </div>
                    <div class="text-center sm:text-left">
                        <p class="text-white font-bold text-sm leading-tight">Garantía</p>
                        <p class="text-gray-400 text-xs">Por escrito</p>
                    </div>
                </div>
                <div class="flex flex-col items-center sm:items-start sm:flex-row gap-2 sm:gap-3 bg-white/10 backdrop-blur-sm border border-white/10 rounded-xl px-3 sm:px-5 py-3 sm:py-4">
                    <div class="w-10 h-10 rounded-lg bg-blue-500/20 flex items-center justify-center flex-shrink-0">
                        <span class="material-icons-outlined text-blue-400 text-xl">schedule</span>
                    </div>
                    <div class="text-center sm:text-left">
                        <p class="text-white font-bold text-sm leading-tight">Respuesta</p>
                        <p class="text-gray-400 text-xs">En 24 horas</p>
                    </div>
                </div>
                <div class="flex flex-col items-center sm:items-start sm:flex-row gap-2 sm:gap-3 bg-white/10 backdrop-blur-sm border border-white/10 rounded-xl px-3 sm:px-5 py-3 sm:py-4">
                    <div class="w-10 h-10 rounded-lg bg-amber-500/20 flex items-center justify-center flex-shrink-0">
                        <span class="material-icons-outlined text-amber-400 text-xl">workspace_premium</span>
                    </div>
                    <div class="text-center sm:text-left">
                        <p class="text-white font-bold text-sm leading-tight">Servicio</p>
                        <p class="text-gray-400 text-xs">Premium</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Subtle section transition -->
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-10">
        <svg viewBox="0 0 1200 60" preserveAspectRatio="none" class="relative block w-full h-[24px] md:h-[40px]">
            <path d="M0,30 C300,55 900,5 1200,30 L1200,60 L0,60 Z" fill="white"></path>
        </svg>
    </div>
</section>
