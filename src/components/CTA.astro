---
import { WHATSAPP } from '../config/site';
---

<section id="contacto" class="relative py-20 md:py-24 overflow-hidden">
    <!-- Bright, engaging background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-blue-600 via-blue-500 to-cyan-500"></div>

    <!-- Decorative -->
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center mb-10 reveal">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mb-4 drop-shadow-sm">
                ¿Necesitas asistencia inmediata?
            </h2>
            <p class="text-blue-50 text-lg md:text-xl max-w-2xl mx-auto drop-shadow-sm">
                Estoy listo para atenderte. Escríbeme y recibe atención personalizada.
            </p>
        </div>

        <!-- Single primary CTA -->
        <div class="flex justify-center reveal" style="transition-delay: 200ms;">
            <a href={WHATSAPP.default} target="_blank" class="px-12 py-5 bg-white hover:bg-gray-50 text-blue-600 font-extrabold rounded-2xl shadow-xl shadow-blue-900/20 transition-all duration-300 transform hover:-translate-y-1 flex items-center justify-center gap-3 text-lg group">
                <svg class="w-6 h-6 text-green-500 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                Escríbeme por WhatsApp
            </a>
        </div>

        <!-- Trust line -->
        <div class="flex items-center justify-center mt-10 gap-8 text-blue-100 text-sm reveal" style="transition-delay: 400ms;">
            <span class="flex items-center gap-2 font-medium"><span class="material-icons-outlined text-lg opacity-80">verified</span> Sin compromiso</span>
            <span class="hidden sm:flex items-center gap-2 font-medium"><span class="material-icons-outlined text-lg opacity-80">schedule</span> Atención inmediata</span>
            <span class="flex items-center gap-2 font-medium"><span class="material-icons-outlined text-lg opacity-80">thumb_up</span> Precios justos</span>
        </div>
    </div>
</section>
