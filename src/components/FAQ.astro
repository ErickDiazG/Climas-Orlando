---
const faqs = [
    {
        question: "¿Qué marcas de minisplits manejan?",
        answer: "Soy distribuidor autorizado de equipos Mirage, y también doy servicio a todas las marcas principales: Carrier, LG, Samsung, Whirlpool, Mabe, Daikin, entre otras.",
    },
    {
        question: "¿Cuánto cuesta el diagnóstico a domicilio?",
        answer: "El diagnóstico a domicilio tiene un costo accesible que se descuenta del total si decides realizar la reparación conmigo. Contáctame por WhatsApp para conocer el precio actual.",
    },
    {
        question: "¿Ofrecen garantía en sus reparaciones?",
        answer: "Sí, todas mis reparaciones incluyen garantía por escrito. Utilizo únicamente refacciones nuevas y originales para asegurar la durabilidad del trabajo realizado.",
    },
    {
        question: "¿En cuánto tiempo pueden atenderme?",
        answer: "Cuento con disponibilidad inmediata. En la mayoría de los casos puedo atenderte el mismo día o al día siguiente de tu llamada. Para urgencias, contáctame directamente por WhatsApp.",
    },
    {
        question: "¿Qué áreas cubren en Reynosa?",
        answer: "Cubro toda la ciudad de Reynosa y sus alrededores, incluyendo todas las colonias y fraccionamientos. También atiendo zonas industriales y comerciales.",
    },
    {
        question: "¿Qué incluye el mantenimiento preventivo de un minisplit?",
        answer: "Mi servicio de mantenimiento incluye: limpieza química profunda de evaporador y condensador, revisión de presiones de gas, limpieza de filtros, verificación eléctrica completa, y revisión de drenaje. Todo para que tu equipo funcione al 100%.",
    },
];
---

<section id="faq" class="py-20 md:py-28 bg-gray-50 relative border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16 reveal">
            <span class="inline-block text-blue-600 font-bold text-sm tracking-widest uppercase mb-3">FAQ</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 mb-4">
                Preguntas frecuentes
            </h2>
            <p class="text-slate-600 text-lg max-w-2xl mx-auto">
                Resuelvo tus dudas antes de contactarme.
            </p>
        </div>

        <!-- FAQ Accordion -->
        <div class="space-y-4 reveal-stagger" id="faq-container">
            {faqs.map((faq, i) => (
                <div class="faq-item bg-white border border-gray-200 rounded-2xl overflow-hidden hover:border-blue-300 hover:shadow-md transition-all duration-300">
                    <button
                        class="faq-trigger w-full flex items-center justify-between p-6 text-left focus:outline-none group"
                        data-index={i}
                        aria-expanded="false"
                    >
                        <svg class="w-6 h-6 text-slate-400 group-hover:text-blue-600 transition-all duration-300 flex-shrink-0 faq-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                    </button>
                    <div class="faq-content max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
                        <p class="px-6 pb-6 text-slate-600 text-[15px] leading-relaxed">{faq.answer}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    document.querySelectorAll('.faq-trigger').forEach(button => {
        button.addEventListener('click', () => {
            const item = button.closest('.faq-item');
            const content = item?.querySelector('.faq-content') as HTMLElement | null;
            const icon = button.querySelector('.faq-icon');
            const isOpen = button.getAttribute('aria-expanded') === 'true';

            // Close all other items
            document.querySelectorAll('.faq-item').forEach(otherItem => {
                if (otherItem !== item) {
                    const otherContent = otherItem.querySelector('.faq-content') as HTMLElement | null;
                    const otherIcon = otherItem.querySelector('.faq-icon');
                    const otherButton = otherItem.querySelector('.faq-trigger');
                    if (otherContent) otherContent.style.maxHeight = '0px';
                    otherIcon?.classList.remove('rotate-180');
                    otherButton?.setAttribute('aria-expanded', 'false');
                }
            });

            // Toggle current
            if (!isOpen && content) {
                content.style.maxHeight = content.scrollHeight + 'px';
                icon?.classList.add('rotate-180');
                button.setAttribute('aria-expanded', 'true');
            } else if (content) {
                content.style.maxHeight = '0px';
                icon?.classList.remove('rotate-180');
                button.setAttribute('aria-expanded', 'false');
            }
        });
    });
</script>

<style>
    .faq-icon {
        transition: transform 0.3s ease;
    }
</style>
