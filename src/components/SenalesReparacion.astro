---
import { WHATSAPP } from '../config/site';

const signals = [
    {
        title: "Ruidos extraños",
        description: "Zumbidos, vibraciones o golpes al encender. Puede ser el compresor, el ventilador o piezas sueltas.",
        icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" /></svg>`
    },
    {
        title: "No enfría suficiente",
        description: "El aire sale tibio o tarda mucho en enfriar. Puede ser falta de gas, filtros sucios o falla eléctrica.",
        icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.467 5.99 5.99 0 0 0-1.925 3.546 5.974 5.974 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" /></svg>`
    },
    {
        title: "Factura de luz elevada",
        description: "Un aumento repentino en tu recibo puede indicar que tu equipo trabaja de más por una falla interna.",
        icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" /></svg>`
    },
    {
        title: "Fugas de agua",
        description: "Goteo dentro o fuera de la unidad. Generalmente indica obstrucción en el drenaje o congelamiento.",
        icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25c-2.25 3.75-6.75 7.5-6.75 12a6.75 6.75 0 0 0 13.5 0c0-4.5-4.5-8.25-6.75-12Z" /></svg>`
    },
    {
        title: "Olores inusuales",
        description: "Olores a humedad, quemado o moho al encender. Señal de acumulación de bacterias o problemas eléctricos.",
        icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Zm0 13.036h.008v.008H12v-.008Z" /></svg>`
    },
    {
        title: "Se congela el equipo",
        description: "Hielo en las tuberías o en el evaporador. Puede ser gas bajo, filtro tapado o fallo del termostato.",
        icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>`
    }
];
---

<section class="py-20 bg-slate-50 overflow-hidden relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <!-- Section Header -->
        <div class="text-center mb-14 reveal">
            <span class="inline-block text-blue-600 font-bold text-xs tracking-[0.2em] uppercase mb-3">¿Tu equipo falla?</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-slate-900 uppercase leading-tight mb-5">
                Señales de que necesitas<br class="hidden sm:block" /> una revisión
            </h2>
            <p class="text-slate-500 max-w-2xl mx-auto text-sm md:text-base leading-relaxed">
                Si tu aire acondicionado presenta alguno de estos síntomas, es momento de actuar antes de que el problema crezca.
            </p>
        </div>

        <!-- Signals Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
            {signals.map(signal => (
                <div class="group bg-slate-50 hover:bg-slate-900 border border-slate-200 hover:border-slate-700 rounded-2xl p-7 transition-all duration-300 cursor-default">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-blue-100 group-hover:bg-blue-600 flex items-center justify-center flex-shrink-0 transition-colors duration-300">
                            <span class="text-blue-600 group-hover:text-white transition-colors duration-300">
                                <Fragment set:html={signal.icon} />
                            </span>
                        </div>
                        <div class="flex-1">
                            <h3 class="text-slate-900 group-hover:text-white font-bold text-base uppercase tracking-tight mb-1.5 transition-colors duration-300">
                                {signal.title}
                            </h3>
                            <p class="text-slate-500 group-hover:text-slate-400 text-sm leading-relaxed transition-colors duration-300">
                                {signal.description}
                            </p>
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <!-- CTA -->
        <div class="text-center reveal">
            <a href={WHATSAPP.default} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-xl text-sm shadow-lg transition-all duration-300 hover:-translate-y-0.5 uppercase tracking-wider">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                ¿Tu equipo tiene estos síntomas? Contáctanos
            </a>
        </div>

    </div>
</section>
