---
import { WHATSAPP } from '../config/site';

const minisplitSymptoms = [
    "Ya no enfría como antes o echa aire al tiempo.",
    "Tira agua hacia adentro de la habitación.",
    "Hace ruidos extraños, zumbidos o vibra mucho.",
    "Huele mal (a humedad o polvo) al encenderlo.",
    "Se apaga solo o marca un código de error en la pantalla."
];

const washerSymptoms = [
    "No centrifuga o la ropa sale empapada.",
    "No tira el agua (no desagua).",
    "Hace mucho ruido o golpea fuerte al centrifugar.",
    "No enciende, se pausa a medio ciclo o parpadean las luces.",
    "Tira agua por debajo o huele a quemado."
];
---

<section class="py-20 lg:py-28 bg-dark-950 relative overflow-hidden">
    <!-- Background decorations -->
    <div class="absolute top-0 right-1/4 w-72 h-72 bg-brand-500/10 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-warm-500/10 rounded-full blur-[120px]"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Section Header -->
        <div class="text-center mb-16">
            <span class="inline-block text-warm-400 font-semibold text-xs uppercase tracking-[0.2em] mb-3">Importante</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-5 leading-tight">
                ¿Tu equipo tiene<span class="text-warm-400"> estos síntomas</span>?
            </h2>
            <p class="text-slate-400 max-w-2xl mx-auto text-lg leading-relaxed">
                Estas son señales claras de que necesitas una revisión urgente antes de que el problema sea más costoso.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 mb-12">
            <!-- Minisplit Card -->
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8 transition-all duration-300 hover:bg-white/10 hover:border-white/20 group">
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-12 h-12 bg-brand-500/20 rounded-xl flex items-center justify-center text-brand-400 group-hover:bg-brand-500 group-hover:text-white transition-colors">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">En tu Minisplit</h3>
                </div>
                
                <ul class="space-y-4">
                    {minisplitSymptoms.map((symptom) => (
                        <li class="flex items-start gap-3">
                            <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-warm-500/20 flex items-center justify-center">
                                <svg class="w-3 h-3 text-warm-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                            </span>
                            <span class="text-slate-300 text-sm leading-relaxed">{symptom}</span>
                        </li>
                    ))}
                </ul>
            </div>

            <!-- Washer Card -->
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 lg:p-8 transition-all duration-300 hover:bg-white/10 hover:border-white/20 group">
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-12 h-12 bg-warm-500/20 rounded-xl flex items-center justify-center text-warm-400 group-hover:bg-warm-500 group-hover:text-white transition-colors">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-white">En tu Lavadora</h3>
                </div>
                
                <ul class="space-y-4">
                    {washerSymptoms.map((symptom) => (
                        <li class="flex items-start gap-3">
                            <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-warm-500/20 flex items-center justify-center">
                                <svg class="w-3 h-3 text-warm-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                            </span>
                            <span class="text-slate-300 text-sm leading-relaxed">{symptom}</span>
                        </li>
                    ))}
                </ul>
            </div>
        </div>

        <!-- CTA Button -->
        <div class="text-center">
            <a href={WHATSAPP.default} target="_blank"
               class="inline-flex items-center gap-3 px-8 py-4 bg-brand-500 hover:bg-brand-400 text-white font-bold rounded-xl shadow-lg shadow-brand-500/25 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" /></svg>
                Agendar Revisión Hoy
            </a>
        </div>
    </div>
</section>
