---
import { Image } from 'astro:assets';

interface Props {
    title: string;
    description: string;
    imageSrc: any; // Astro image metadata
    imageAlt: string;
    features: string[];
    ctaText: string;
    ctaLink: string;
    icon: string;
    imageClass?: string;
}

const { title, description, imageSrc, imageAlt, features, ctaText, ctaLink, icon, imageClass = "" } = Astro.props;
---

<div class="group relative flex flex-col bg-white rounded-2xl overflow-hidden shadow-[0_20px_60px_-12px_rgba(30,58,138,0.06)] hover:shadow-xl transition-all duration-300 ease-in-out border-l-4 border-l-blue-600 hover:-translate-y-2">
    <!-- Image -->
    <div class="relative h-56 overflow-hidden">
        <Image
            src={imageSrc}
            alt={imageAlt}
            width={400}
            height={300}
            class={`w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700 ease-out ${imageClass}`}
            loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/10 to-transparent"></div>
    </div>

    <!-- Icon Badge (subtle) -->
    <div class="absolute top-[196px] left-5 w-11 h-11 bg-white text-blue-600 rounded-xl flex items-center justify-center shadow-md border border-gray-100 z-10 group-hover:bg-blue-50 group-hover:text-blue-700 transition-colors">
        <Fragment set:html={icon} />
    </div>


    <!-- Content -->
    <div class="p-6 pt-10 flex flex-col flex-grow">
        <h3 class="text-xl font-extrabold text-slate-900 mb-3 group-hover:text-blue-600 transition-colors duration-300">{title}</h3>
        <p class="text-slate-600 text-[15px] leading-relaxed mb-5 flex-grow">{description}</p>

        <ul class="space-y-2.5 mb-6">
            {features.map((feature) => (
                <li class="flex items-center gap-2.5 text-sm text-slate-600">
                    <span class="w-5 h-5 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
                        <svg class="w-3 h-3 text-green-600 stroke-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    </span>
                    {feature}
                </li>
            ))}
        </ul>

        <a href={ctaLink} target="_blank" class="mt-auto inline-flex items-center justify-center gap-2 w-full px-5 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg text-sm transition-all duration-300">
            {ctaText}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>
    </div>
</div>
